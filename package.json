{
  "name": "launchpad",
  "version": "1.0.0",
  "type": "module",
  "description": "ESMT Berlin Ideation Bootcamp — AI-Native Startup Builder",
  "scripts": {
    "setup": "node setup.js",
    "dev": "concurrently \"vite\" \".venv/bin/python -m uvicorn backend.server:app --reload --reload-dir backend --port 3004\"",
    "dev:frontend": "vite",
    "dev:backend": ".venv/bin/python -m uvicorn backend.server:app --reload --reload-dir backend --port 3004",
    "build": "vite build",
    "test": ".venv/bin/python -m pytest && npx vitest run",
    "test:py": ".venv/bin/python -m pytest",
    "test:js": "npx vitest run",
    "test:watch": "npx vitest"
  },
  "dependencies": {
    "@remotion/player": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "framer-motion": "^11.15.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.13.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
